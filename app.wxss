page {
  --color-primary: #FF6B35;
  --color-primary-light: #FF8F65;
  --color-primary-dark: #E55A25;
  --color-bg: #F2F3F8;
  --color-bg-card: #FFFFFF;
  --color-bg-card-light: #F0F1F6;
  --color-bg-input: #EDEEF4;
  --color-text: #1C1C2E;
  --color-text-secondary: #6E6E82;
  --color-text-muted: #A5A5B8;
  --color-success: #34C759;
  --color-success-light: #5DD47A;
  --color-danger: #FF3B30;
  --color-border: #E5E5EE;
  --color-rest: #7C4DFF;

  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  --shadow-card-hover: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);

  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-full: 999rpx;

  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

.container {
  padding: var(--spacing-lg);
  padding-bottom: 120rpx;
}

.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-card);
}

.btn-primary {
  background: var(--color-primary);
  color: #fff;
  border: none;
  border-radius: var(--radius-full);
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  line-height: 1.5;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: var(--color-bg-card);
  color: var(--color-text);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-full);
  padding: 18rpx 44rpx;
  font-size: 28rpx;
  text-align: center;
  line-height: 1.5;
  box-shadow: var(--shadow-card);
}

.btn-secondary::after {
  border: none;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: var(--spacing-md);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
  text-align: center;
}

.empty-state .empty-icon {
  font-size: 96rpx;
  margin-bottom: var(--spacing-lg);
  opacity: 0.5;
}

.empty-state .empty-text {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-lg);
}
