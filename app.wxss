page {
  --color-primary: #FF6B35;
  --color-primary-light: #FF8F65;
  --color-primary-dark: #E55A25;
  --color-bg: #121225;
  --color-bg-card: #1A1A2E;
  --color-bg-card-light: #222240;
  --color-bg-input: #2A2A45;
  --color-text: #EAEAF0;
  --color-text-secondary: #8E8EA0;
  --color-text-muted: #5A5A70;
  --color-success: #4CAF50;
  --color-success-light: #66BB6A;
  --color-danger: #F44336;
  --color-border: #2E2E48;
  --color-rest: #7C4DFF;

  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-full: 999rpx;

  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

.container {
  padding: var(--spacing-lg);
  padding-bottom: 120rpx;
}

.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
}

.btn-primary {
  background: var(--color-primary);
  color: #fff;
  border: none;
  border-radius: var(--radius-full);
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  line-height: 1.5;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: var(--color-bg-card-light);
  color: var(--color-text);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-full);
  padding: 18rpx 44rpx;
  font-size: 28rpx;
  text-align: center;
  line-height: 1.5;
}

.btn-secondary::after {
  border: none;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: var(--spacing-md);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
  text-align: center;
}

.empty-state .empty-icon {
  font-size: 96rpx;
  margin-bottom: var(--spacing-lg);
  opacity: 0.5;
}

.empty-state .empty-text {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-lg);
}
