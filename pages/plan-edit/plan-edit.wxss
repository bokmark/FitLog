.page-header {
  margin-bottom: var(--spacing-lg);
}

.page-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-text);
}

.name-card {
  margin-bottom: var(--spacing-lg);
}

.form-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 72rpx;
  background: var(--color-bg-input);
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.exercise-list {
  margin-bottom: var(--spacing-lg);
}

.edit-exercise-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-sm);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.edit-card-main {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg);
}

.edit-card-order {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
  margin-right: var(--spacing-md);
}

.edit-card-info {
  flex: 1;
  min-width: 0;
}

.edit-card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 4rpx;
}

.edit-card-detail {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.edit-card-media {
  font-size: 22rpx;
  color: var(--color-primary);
  margin-top: 4rpx;
}

.edit-arrow {
  font-size: 36rpx;
  color: var(--color-text-muted);
  font-weight: bold;
  flex-shrink: 0;
}

.edit-card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  padding: 0 var(--spacing-lg) var(--spacing-md);
}

.action-btn {
  padding: 8rpx 24rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
}

.move-btn {
  background: var(--color-bg-card-light);
  color: var(--color-text-secondary);
}

.delete-btn {
  background: rgba(244, 67, 54, 0.15);
  color: var(--color-danger);
}

.empty-hint {
  text-align: center;
  padding: 80rpx 0;
  color: var(--color-text-muted);
  font-size: 28rpx;
}

.add-btn {
  margin-top: var(--spacing-md);
  width: 100%;
}
