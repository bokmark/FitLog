.search-bar {
  margin-bottom: var(--spacing-md);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-full);
  padding: 16rpx 24rpx;
  gap: 12rpx;
  box-shadow: var(--shadow-card);
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
  height: 48rpx;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--color-bg-card-light);
  color: var(--color-text-secondary);
  font-size: 22rpx;
  flex-shrink: 0;
}

.stats-bar {
  margin-bottom: var(--spacing-md);
}

.stats-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.exercise-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.ex-card {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  gap: var(--spacing-md);
  box-shadow: var(--shadow-card);
}

.ex-card-left {
  flex-shrink: 0;
}

.ex-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  background: var(--color-bg-card-light);
  display: flex;
  align-items: center;
  justify-content: center;
}

.thumb-img {
  width: 100%;
  height: 100%;
}

.thumb-video {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-card-light);
}

.thumb-play {
  font-size: 36rpx;
  color: var(--color-primary);
}

.thumb-placeholder-icon {
  font-size: 40rpx;
  opacity: 0.4;
}

.ex-card-center {
  flex: 1;
  min-width: 0;
}

.ex-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ex-detail {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.sep {
  margin: 0 6rpx;
}

.ex-days {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.day-tag {
  font-size: 20rpx;
  color: var(--color-primary);
  background: rgba(255, 107, 53, 0.12);
  padding: 2rpx 14rpx;
  border-radius: var(--radius-full);
  line-height: 1.6;
}

.ex-card-right {
  flex-shrink: 0;
}

.ex-arrow {
  font-size: 36rpx;
  color: var(--color-text-muted);
  font-weight: bold;
}

/* FAB */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 28rpx rgba(255, 107, 53, 0.35);
  z-index: 100;
}

.fab-icon {
  font-size: 52rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

/* Day Picker */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}

.picker-sheet {
  width: 100%;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: var(--spacing-lg);
  padding-bottom: calc(var(--spacing-xl) + env(safe-area-inset-bottom));
  animation: sheetUp 0.25s ease;
  box-shadow: 0 -4rpx 30rpx rgba(0, 0, 0, 0.1);
}

@keyframes sheetUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.picker-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  text-align: center;
  margin-bottom: var(--spacing-lg);
}

.picker-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-bottom: var(--spacing-lg);
}

.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx var(--spacing-md);
  background: var(--color-bg-card-light);
  border-radius: var(--radius-sm);
  font-size: 30rpx;
  color: var(--color-text);
}

.picker-arrow {
  font-size: 32rpx;
  color: var(--color-text-muted);
  font-weight: bold;
}

.picker-cancel {
  text-align: center;
  padding: 24rpx;
  font-size: 30rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg-card-light);
  border-radius: var(--radius-sm);
}
