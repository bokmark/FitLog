.viewer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.viewer-content {
  width: 90%;
  max-height: 80vh;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.viewer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-lg);
}

.viewer-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--color-bg-card-light);
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.viewer-body {
  padding: 0 var(--spacing-lg) var(--spacing-lg);
}

.media-image {
  width: 100%;
  max-height: 60vh;
  border-radius: var(--radius-md);
}

.media-video {
  width: 100%;
  height: 450rpx;
  border-radius: var(--radius-md);
}
