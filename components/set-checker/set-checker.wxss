.set-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border);
  transition: all 0.3s ease;
}

.set-row:last-child {
  border-bottom: none;
}

.set-row.completed {
  opacity: 0.7;
}

.set-index {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  width: 100rpx;
  flex-shrink: 0;
}

.set-info {
  flex: 1;
  min-width: 0;
}

.set-target {
  font-size: 26rpx;
  color: var(--color-text);
}

.set-actual {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  gap: 8rpx;
}

.actual-input {
  width: 100rpx;
  height: 48rpx;
  background: var(--color-bg-input);
  border-radius: var(--radius-sm);
  padding: 0 12rpx;
  font-size: 24rpx;
  color: var(--color-primary);
  text-align: center;
}

.dot {
  color: var(--color-text-muted);
  font-size: 24rpx;
}

.unit {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.check-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.check-btn.checked {
  background: var(--color-success);
  border-color: var(--color-success);
}

.check-btn text {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.check-status {
  flex-shrink: 0;
}

.done-mark {
  color: var(--color-success);
  font-size: 28rpx;
  font-weight: bold;
}
